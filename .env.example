# Database Configuration
POSTGRES_USER=virusradar
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=virusradar_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Database URL (wird automatisch generiert, kann aber überschrieben werden)
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# API Keys
OPENWEATHER_API_KEY=your-openweather-api-key-here

# vLLM Configuration (OpenAI-compatible, strictly local)
# In Docker (prod) empfehlen wir: http://host.docker.internal:8000/v1
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_API_KEY=local

# Media AI Async Refinement (Top-Cards after Generate)
MEDIA_AI_ASYNC_REFINEMENT_ENABLED=true
MEDIA_AI_BULK_REFINE_TOP_N=3
MEDIA_AI_REFINEMENT_POLL_HINT_SECONDS=5

# Celery / Redis (Async Tasks)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Optional: ganzimmun Internal Data API
GANZIMMUN_API_URL=
GANZIMMUN_API_KEY=

# Security — generate with: openssl rand -base64 32
SECRET_KEY=generate-a-secure-random-key-here-minimum-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Admin credentials (REQUIRED — no defaults, min 12 chars password)
ADMIN_EMAIL=admin@your-domain.de
ADMIN_PASSWORD=generate-a-strong-password-here

# Machine-to-machine webhook auth (REQUIRED for ERP/IMS integrations)
M2M_SECRET_KEY=generate-a-secure-m2m-key-here

# CORS Settings
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Data Update Schedule (Cron Format)
# Default: Täglich um 6:00 Uhr
DATA_UPDATE_CRON=0 6 * * *
SURVSTAT_LOCAL_DIR=/app/data/raw/survstat

# ML Model Settings
FORECAST_DAYS=14
CONFIDENCE_LEVEL=0.95

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Application
APP_NAME=LabPulse Pro
APP_VERSION=1.0.0
ENVIRONMENT=development

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Cache Settings
CACHE_TTL=3600
