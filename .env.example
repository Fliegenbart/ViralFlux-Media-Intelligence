# Database Configuration
POSTGRES_USER=virusradar
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=virusradar_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Database URL (wird automatisch generiert, kann aber überschrieben werden)
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# API Keys
OPENWEATHER_API_KEY=your-openweather-api-key-here

# Ollama Configuration
OLLAMA_URL=http://your-hetzner-server:11434
OLLAMA_MODEL=llama2

# Optional: ganzimmun Internal Data API
GANZIMMUN_API_URL=
GANZIMMUN_API_KEY=

# Security
SECRET_KEY=generate-a-secure-random-key-here-minimum-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Settings
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Data Update Schedule (Cron Format)
# Default: Täglich um 6:00 Uhr
DATA_UPDATE_CRON=0 6 * * *
SURVSTAT_LOCAL_DIR=/app/data/raw/survstat

# ML Model Settings
FORECAST_DAYS=14
CONFIDENCE_LEVEL=0.95

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Application
APP_NAME=LabPulse Pro
APP_VERSION=1.0.0
ENVIRONMENT=development

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Cache Settings
CACHE_TTL=3600
